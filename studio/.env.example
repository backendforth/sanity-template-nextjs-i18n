# Sanity Studio — copy to `.env` (same `SANITY_STUDIO_PROJECT_ID` as `web/.env.local`)

SANITY_STUDIO_PROJECT_ID=

# --- Dataset (`@repo/sanity-dataset-resolve`, `config/sync/studioDataset.ts`) ---
# Default: auto (dev-first locally / prod-first on production-style deploys; see package README).
#
# Same override as web — set `SANITY_STUDIO_DEPLOYMENT_TARGET` on the **Studio build’s** env
# (e.g. Sanity deploy env vars) to match your staging/preview dataset name (`staging`, etc.).
# SANITY_STUDIO_DEPLOYMENT_TARGET=staging
#
# Hard pin one dataset (skip auto-selection). Filled by `npm create sanity`;
# leave empty for auto-selection.
SANITY_STUDIO_DATASET=
#
# Optional: rename canonical dev/prod labels if your project uses different dataset names.
# SANITY_STUDIO_DATASET_DEVELOPMENT=development
# SANITY_STUDIO_DATASET_PRODUCTION=production
# Dataset sync: `pnpm run sync:prod-to-dev` in `studio/` (or `pnpm studio:sync-prod-to-dev` from repo root).

# --- Optional: dataset-probing token ---
# Used by `@repo/sanity-dataset-resolve` to enumerate datasets via the Management API
# when `SANITY_STUDIO_DATASET` is not pinned (avoids the public probe fallback).
#   SANITY_API_READ_TOKEN=                (same as web — also enables draft reads)
#   SANITY_STUDIO_DATASET_RESOLVER_TOKEN= (Management-style token; only used for dataset probing)

# --- Presentation / Visual Editing ---
# Must match the Next app URL in the iframe (scheme + host + port). localhost:3000 ≠ 127.0.0.1:3000.
SANITY_STUDIO_PREVIEW_ORIGIN=http://localhost:3000
# SANITY_STUDIO_WEB_PREVIEW_ORIGINS=https://your-site.netlify.app,https://deploy-preview-42--your-site.netlify.app

# --- Optional: Mux (sanity-plugin-mux-input) ---
# SANITY_STUDIO_MUX_TOKEN_ID=
# SANITY_STUDIO_MUX_TOKEN_SECRET=
# One-off: `pnpm mux:migrate-assets` (dry-run) / `pnpm mux:migrate-assets -- --apply`
