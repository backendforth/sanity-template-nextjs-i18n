{
  "name": "studio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-with-hint.mjs",
    "sync:prod-to-dev": "node scripts/sync-prod-to-dev.mjs",
    "migrate:project-body-rich-text": "node scripts/migrate-project-body-rich-text.mjs",
    "mux:migrate-assets": "node scripts/mux-migrate-assets.mjs",
    "start": "sanity start",
    "build": "sanity build",
    "deploy": "SANITY_STUDIO_DEPLOYMENT_TARGET=production sanity deploy",
    "generate": "sanity schema extract --enforce-required-fields && sanity typegen generate",
    "lint": "pnpm --workspace-root exec biome check studio",
    "format": "pnpm --workspace-root exec biome format --write studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/sanity-dataset-resolve": "workspace:*",
    "@sanity/code-input": "^7.2.5",
    "@sanity/dashboard": "^6.0.8",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^6.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rxjs": "^7.8.2",
    "sanity": "^6.3.0",
    "sanity-plugin-internationalized-array": "^5.1.16",
    "sanity-plugin-media": "^4.3.1",
    "sanity-plugin-mux-input": "^3.0.0",
    "sanity-plugin-netlify": "^1.4.0",
    "styled-components": "^6.4.3"
  },
  "devDependencies": {
    "@sanity/client": "^7.23.0",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "typescript": "^6.0.3"
  }
}
